#!/usr/bin/env bash
# Matrix3D single-image overfit config for indoor Manhattan apartment.
# Usage:
#   bash scripts/single_view_to_3d_overfit.sh configs/single_view_overfit_manhattan.env

# Experiment naming
EXP_NAME="single-view-to-3d-overfit-manhattan"
INPUT_PATH="assets/manhattan_apt.png"

# Matrix3D generation
GPU_ID=0
MIXED_PRECISION="fp16"
DEFAULT_FOV=80
NUM_SAMPLES=120
RANDOM_SEED=1
CHECKPOINT_PATH="checkpoints/matrix3d_512.pt"
STAGE3_CONFIG="configs/config_stage3.yaml"

# Nerfstudio overfit settings
ITERS=12000
NUM_IMG=12
SH_DEGREE=3
LPIPS_LAMBDA=12.0
DEPTH_L1_LAMBDA=12.0
DEPTH_RANKING_LAMBDA=12.0
L1_CAPTURED=22.0
L1_GENERATED=1.2
SAVE_EVERY=1000
